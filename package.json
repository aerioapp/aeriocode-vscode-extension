{
	"name": "Aerio-Code",
	"displayName": "Aerio Code",
	"description": "AI-powered aerospace and engineering coding assistant for VS Code.",
	"version": "0.0.4",
	"icon": "assets/icons/icon.png",
	"engines": {
		"vscode": "^1.84.0"
	},
	"author": {
		"name": "Aerio"
	},
	"license": "SEE LICENSE IN LICENSE",
	"publisher": "aerio",
	"repository": {
		"type": "git",
		"url": "https://github.com/aerioapp/aeriocode-vscode-extension"
	},
	"homepage": "https://aerio.bot",
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"keywords": [
		"aeriocode",
		"dev",
		"mcp",
		"coding",
		"agent",
		"autonomous",
		"ai"
	],
	"activationEvents": [
		"onLanguage",
		"onStartupFinished",
		"workspaceContains:evals.env",
		"onUri"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"walkthroughs": [
			{
				"id": "AeriocodeWalkthrough",
				"title": "Meet Aeriocode, your new coding partner",
				"description": "Aeriocode codes like a developer because it thinks like one. Here are 5 ways to put it to work:",
				"steps": [
					{
						"id": "welcome",
						"title": "Start with a Goal, Not Just a Prompt",
						"description": "Tell Aeriocode what you want to achieve. It plans, asks, and then codes, like a true partner.",
						"media": {
							"markdown": "walkthrough/step1.md"
						}
					},
					{
						"id": "learn",
						"title": "Let Aeriocode Learn Your Codebase",
						"description": "Point Aeriocode to your project. It builds understanding to make smart, context-aware changes.",
						"media": {
							"markdown": "walkthrough/step2.md"
						}
					},
					{
						"id": "advanced-features",
						"title": "Always Use the Best AI Models",
						"description": "Aeriocode empowers you with State-of-the-Art AI, connecting to top models (Anthropic, Gemini, OpenAI & more).",
						"media": {
							"markdown": "walkthrough/step3.md"
						}
					},
					{
						"id": "mcp",
						"title": "Extend with Powerful Tools (MCP)",
						"description": "Connect to databases, APIs, or discover new capabilities in the MCP Marketplace.",
						"media": {
							"markdown": "walkthrough/step4.md"
						}
					},
					{
						"id": "getting-started",
						"title": "You're Always in Control",
						"description": "Review Aeriocode's plans and diffs. Approve changes before they happen. No surprises.",
						"media": {
							"markdown": "walkthrough/step5.md"
						},
						"content": {
							"path": "walkthrough/step5.md"
						}
					}
				]
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "aeriocode-ActivityBar",
					"title": "Aeriocode (⌘+')",
					"icon": "assets/icons/icon.svg",
					"when": "isMac"
				},
				{
					"id": "aeriocode-ActivityBar",
					"title": "Aeriocode (Ctrl+')",
					"icon": "assets/icons/icon.svg",
					"when": "!isMac"
				}
			]
		},
		"views": {
			"aeriocode-ActivityBar": [
				{
					"type": "webview",
					"id": "aeriocode.SidebarProvider",
					"name": "",
					"icon": "assets/icons/icon.svg"
				}
			]
		},
		"commands": [
			{
				"command": "aeriocode.plusButtonClicked",
				"title": "New Task",
				"icon": "$(add)"
			},
			{
				"command": "aeriocode.mcpButtonClicked",
				"title": "MCP Servers",
				"icon": "$(server)"
			},
			{
				"command": "aeriocode.historyButtonClicked",
				"title": "History",
				"icon": "$(history)"
			},
			{
				"command": "aeriocode.popoutButtonClicked",
				"title": "Open in Editor",
				"icon": "$(link-external)"
			},
			{
				"command": "aeriocode.accountButtonClicked",
				"title": "Account",
				"icon": "$(account)"
			},
			{
				"command": "aeriocode.settingsButtonClicked",
				"title": "Settings",
				"icon": "$(settings-gear)"
			},
			{
				"command": "aeriocode.traceabilityButtonClicked",
				"title": "Traceability",
				"icon": "$(checklist)"
			},
			{
				"command": "aeriocode.auditTrailButtonClicked",
				"title": "Audit Trail",
				"icon": "$(shield)"
			},
			{
				"command": "aeriocode.openInNewTab",
				"title": "Open In New Tab",
				"category": "Aeriocode"
			},
			{
				"command": "aeriocode.dev.createTestTasks",
				"title": "Create Test Tasks",
				"category": "Aeriocode",
				"when": "aeriocode.isDevMode"
			},
			{
				"command": "aeriocode.addToChat",
				"title": "Add to Aeriocode",
				"category": "Aeriocode"
			},
			{
				"command": "aeriocode.addTerminalOutputToChat",
				"title": "Add to Aeriocode",
				"category": "Aeriocode"
			},
			{
				"command": "aeriocode.focusChatInput",
				"title": "Jump to Chat Input",
				"category": "Aeriocode"
			},
			{
				"command": "aeriocode.generateGitCommitMessage",
				"title": "Generate Commit Message with Aeriocode",
				"category": "Aeriocode",
				"icon": "$(robot)"
			},
			{
				"command": "aeriocode.abortGitCommitMessage",
				"title": "Generate Commit Message with Aeriocode - Stop",
				"category": "Aeriocode",
				"icon": "$(debug-stop)"
			},
			{
				"command": "aeriocode.explainCode",
				"title": "Explain with Aeriocode",
				"category": "Aeriocode"
			},
			{
				"command": "aeriocode.improveCode",
				"title": "Improve with Aeriocode",
				"category": "Aeriocode"
			},
			{
				"command": "aeriocode.openWalkthrough",
				"title": "Open Walkthrough",
				"category": "Aeriocode"
			},
			{
				"command": "aeriocode.jupyterGenerateCell",
				"title": "Generate Jupyter Cell with Aeriocode",
				"category": "Aeriocode",
				"icon": "$(sparkle)"
			},
			{
				"command": "aeriocode.jupyterExplainCell",
				"title": "Explain Jupyter Cell with Aeriocode",
				"category": "Aeriocode",
				"icon": "$(question)"
			},
			{
				"command": "aeriocode.jupyterImproveCell",
				"title": "Improve Jupyter Cell with Aeriocode",
				"category": "Aeriocode",
				"icon": "$(lightbulb)"
			},
			{
				"command": "aeriocode.reconstructTaskHistory",
				"title": "Reconstruct Task History",
				"category": "Aeriocode"
			},
			{
				"command": "aeriocode.reviewComment.reply",
				"title": "Reply",
				"category": "Aeriocode",
				"enablement": "!commentIsEmpty"
			},
			{
				"command": "aeriocode.reviewComment.addToChat",
				"title": "Add to Aeriocode Chat",
				"category": "Aeriocode",
				"icon": "$(link-external)"
			}
		],
		"keybindings": [
			{
				"command": "aeriocode.addToChat",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "editorHasSelection"
			},
			{
				"command": "aeriocode.generateGitCommitMessage",
				"when": "config.git.enabled && scmProvider == git"
			},
			{
				"command": "aeriocode.focusChatInput",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "!editorHasSelection"
			},
			{
				"command": "editor.action.submitComment",
				"key": "enter",
				"when": "commentEditorFocused && commentController == aeriocode-ai-review && !commentIsEmpty"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "aeriocode.plusButtonClicked",
					"group": "navigation@1",
					"when": "view == aeriocode.SidebarProvider"
				},
				{
					"command": "aeriocode.mcpButtonClicked",
					"group": "navigation@2",
					"when": "view == aeriocode.SidebarProvider"
				},
				{
					"command": "aeriocode.historyButtonClicked",
					"group": "navigation@3",
					"when": "view == aeriocode.SidebarProvider"
				},
				{
					"command": "aeriocode.traceabilityButtonClicked",
					"group": "navigation@4",
					"when": "view == aeriocode.SidebarProvider && aeriocode.certificationActive"
				},
				{
					"command": "aeriocode.auditTrailButtonClicked",
					"group": "navigation@5",
					"when": "view == aeriocode.SidebarProvider && aeriocode.certificationActive"
				},
				{
					"command": "aeriocode.popoutButtonClicked",
					"group": "navigation@6",
					"when": "view == aeriocode.SidebarProvider"
				},
				{
					"command": "aeriocode.accountButtonClicked",
					"group": "navigation@7",
					"when": "view == aeriocode.SidebarProvider"
				},
				{
					"command": "aeriocode.settingsButtonClicked",
					"group": "navigation@8",
					"when": "view == aeriocode.SidebarProvider"
				}
			],
			"editor/title": [
				{
					"command": "aeriocode.plusButtonClicked",
					"group": "navigation@1",
					"when": "activeWebviewPanelId == aeriocode.TabPanelProvider"
				},
				{
					"command": "aeriocode.mcpButtonClicked",
					"group": "navigation@2",
					"when": "activeWebviewPanelId == aeriocode.TabPanelProvider"
				},
				{
					"command": "aeriocode.historyButtonClicked",
					"group": "navigation@3",
					"when": "activeWebviewPanelId == aeriocode.TabPanelProvider"
				},
				{
					"command": "aeriocode.traceabilityButtonClicked",
					"group": "navigation@4",
					"when": "activeWebviewPanelId == aeriocode.TabPanelProvider && aeriocode.certificationActive"
				},
				{
					"command": "aeriocode.auditTrailButtonClicked",
					"group": "navigation@5",
					"when": "activeWebviewPanelId == aeriocode.TabPanelProvider && aeriocode.certificationActive"
				},
				{
					"command": "aeriocode.popoutButtonClicked",
					"group": "navigation@6",
					"when": "activeWebviewPanelId == aeriocode.TabPanelProvider"
				},
				{
					"command": "aeriocode.accountButtonClicked",
					"group": "navigation@7",
					"when": "activeWebviewPanelId == aeriocode.TabPanelProvider"
				},
				{
					"command": "aeriocode.settingsButtonClicked",
					"group": "navigation@8",
					"when": "activeWebviewPanelId == aeriocode.TabPanelProvider"
				}
			],
			"editor/context": [
				{
					"command": "aeriocode.addToChat",
					"group": "navigation",
					"when": "editorHasSelection"
				}
			],
			"terminal/context": [
				{
					"command": "aeriocode.addTerminalOutputToChat",
					"group": "navigation"
				}
			],
			"scm/title": [
				{
					"command": "aeriocode.generateGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && !aeriocode.isGeneratingCommit"
				},
				{
					"command": "aeriocode.abortGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && aeriocode.isGeneratingCommit"
				}
			],
			"commandPalette": [
				{
					"command": "aeriocode.generateGitCommitMessage",
					"when": "config.git.enabled && scmProvider == git && !aeriocode.isGeneratingCommit"
				},
				{
					"command": "aeriocode.abortGitCommitMessage",
					"when": "config.git.enabled && scmProvider == git && aeriocode.isGeneratingCommit"
				},
				{
					"command": "aeriocode.reviewComment.reply",
					"when": "false"
				}
			],
			"notebook/toolbar": [
				{
					"command": "aeriocode.jupyterGenerateCell",
					"group": "navigation/add@1",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"notebook/cell/title": [
				{
					"command": "aeriocode.jupyterExplainCell",
					"group": "inline",
					"when": "notebookType == 'jupyter-notebook'"
				},
				{
					"command": "aeriocode.jupyterImproveCell",
					"group": "inline",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"comments/commentThread/context": [
				{
					"command": "aeriocode.reviewComment.reply",
					"group": "inline",
					"when": "commentController == aeriocode-ai-review"
				}
			],
			"comments/commentThread/title": [
				{
					"command": "aeriocode.reviewComment.addToChat",
					"group": "inline",
					"when": "commentController == aeriocode-ai-review"
				}
			]
		},
		"configuration": {
			"title": "Aeriocode",
			"properties": {}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && npm run lint && node esbuild.mjs",
		"compile-standalone": "npm run check-types && npm run lint && node esbuild.mjs --standalone",
		"postcompile-standalone": "node scripts/package-standalone.mjs",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.mjs --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && npm run build:webview && npm run lint && node esbuild.mjs --production",
		"protos": "node scripts/build-proto.mjs",
		"postprotos": "prettier src/shared/proto src/core/controller src/hosts/ webview-ui/src/services --write --log-level warn && [ -d src/generated ] && prettier src/generated --write --log-level warn || true",
		"clean": "rimraf dist dist-standalone webview-ui/build src/generated out/",
		"compile-tests": "node ./scripts/build-tests.js",
		"watch-tests": "tsc -p . -w --outDir out",
		"check-types": "npm run protos && npx tsc --noEmit && cd webview-ui && npx tsc -b --noEmit",
		"lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint src --ext ts && cross-env ESLINT_USE_FLAT_CONFIG=false eslint webview-ui/src --ext ts && buf lint && cd webview-ui && npm run lint",
		"format": "prettier . --check",
		"format:fix": "prettier . --write",
		"pretest": "npm run compile && npm run compile-tests && npm run compile-standalone && npm run lint",
		"test": "npm-run-all test:unit test:integration",
		"test:ci": "node scripts/test-ci.js",
		"test:integration": "vscode-test",
		"test:unit": "TS_NODE_PROJECT='./tsconfig.unit-test.json' mocha",
		"test:coverage": "vscode-test --coverage",
		"e2e": "playwright test -c playwright.config.ts",
		"test:e2e": "playwright install && vsce package --no-dependencies --out dist/e2e.vsix && node src/test/e2e/utils/build.js && playwright test",
		"test:e2e:optimal": "vsce package --no-dependencies --out dist/e2e.vsix && node src/test/e2e/utils/build.js && playwright test",
		"install:all": "npm install && cd webview-ui && npm install",
		"dev:webview": "cd webview-ui && npm run dev",
		"build:webview": "cd webview-ui && npm run build",
		"test:webview": "cd webview-ui && npm run test",
		"publish:marketplace": "vsce publish && ovsx publish",
		"publish:marketplace:prerelease": "vsce publish --pre-release && ovsx publish --pre-release",
		"prepare": "husky",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"docs": "cd docs && npm run dev",
		"docs:check-links": "cd docs && npm run check",
		"docs:rename-file": "cd docs && npm run rename",
		"report-issue": "node scripts/report-issue.js"
	},
	"lint-staged": {
		"*": [
			"prettier --write --ignore-unknown --log-level=log"
		]
	},
